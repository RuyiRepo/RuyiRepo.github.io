---
interface Props {
  title: string
  paragraphs: string[]
}

const { title, paragraphs } = Astro.props
---

<section class="section intro">
  <h1>{title}</h1>
  <div class="prose">
    {paragraphs.map(p => <p>{p}</p>)}
  </div>
</section>

<style>
  .section {
    margin-bottom: 64px;
  }

  h1 {
    margin: 0;
    font-size: 30px;
    font-weight: 700;
  }

  .prose {
    margin-top: 12px;
    color: var(--muted);
    line-height: 1.7;
  }

  .prose p {
    margin: 12px 0 0;
  }
</style>
