---
import type { ServiceData, RepoServiceSection, SupportedSoftwareGridSection } from '@/types'

interface Props {
  data: ServiceData
}

const { data } = Astro.props
const base = import.meta.env.BASE_URL
---

{data.sections.map(section => {
  if (section.type === 'repoService') {
    const s = section as RepoServiceSection
    return (
      <div class="tab-block">
        <h3>{s.repoAddress.label}</h3>
        <div class="code-row">
          <code>{s.repoAddress.url}</code>
          <button class="copy-btn" type="button" data-copy-text={s.repoAddress.url} aria-label="复制">
            <img class="copy-icon" src={`${base}/icons/copy.svg`} alt="" width="16" height="16" />
          </button>
        </div>
        <h3>{s.usageExample.title}</h3>
        <div class="code-row">
         <code>{s.usageExample.code}</code>
          <button class="copy-btn" type="button" data-copy-text={s.usageExample.code} aria-label="复制">
            <img class="copy-icon" src={`${base}/icons/copy.svg`} alt="" width="16" height="16" />
          </button>
        </div>
      </div>
    )
  }

  if (section.type === 'supportedSoftwareGrid') {
    const s = section as SupportedSoftwareGridSection
    return (
      <div class="tab-block">
        <h3>{s.title}</h3>
        <div class="software-grid">
          {s.items.map(item => (
            <div class="software-card">
              <div class="name">{item.name}</div>
              {item.version && <div class="version">{item.version}</div>}
            </div>
          ))}
        </div>
      </div>
    )
  }
})}

<style>
  .tab-block {
    margin-bottom: 24px;
  }

  h3 {
    margin: 18px 0 10px;
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .code-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .code-row code {
    background: #f3f4f6;
    padding: 10px 12px;
    border-radius: 10px;
    flex: 1;
    min-width: 0;
    word-break: break-all;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
    font-size: 13px;
    color: var(--text);
  }

  .code-block {
    background: #f3f4f6;
    color: var(--text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
    padding: 16px;
    border-radius: 10px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin-top: 10px;
  }

  .code-block pre {
    margin: 0;
  }

  .copy-btn {
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: 10px;
    padding: 8px 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: #f9fafb;
  }

  .software-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  .software-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px;
  }

  .software-card .name {
    font-weight: 700;
    color: var(--text);
  }

  .software-card .version {
    margin-top: 6px;
    color: var(--muted);
    font-size: 13px;
  }

  @media (max-width: 900px) {
    .software-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
