---
import Layout from '@/layouts/Layout.astro'
import IntroSection from '@/components/home/IntroSection.astro'
import ServiceSection from '@/components/home/ServiceSection/index.astro'
import FeedbackSection from '@/components/home/FeedbackSection.astro'
import { zh, en } from '@/i18n'

interface Props {
  lang: 'zh' | 'en'
  /** 仅用于 `/` 中文首页：根据浏览器语言尝试跳转英文站 */
  enableRootLocaleRedirect?: boolean
}

const { lang, enableRootLocaleRedirect = false } = Astro.props
const i18n = lang === 'en' ? en : zh
---

<Layout lang={lang} enableRootLocaleRedirect={enableRootLocaleRedirect}>
  <IntroSection title={i18n.intro.title} paragraphs={i18n.intro.paragraphs} />
  <ServiceSection
    title={i18n.servicesTitle}
    lang={lang}
    serviceI18n={i18n.services}
  />
  <FeedbackSection feedback={i18n.feedback} lang={lang} />
</Layout>
