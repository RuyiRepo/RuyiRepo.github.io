---
import Header from './Header.astro'
import { baseUrl } from '@/lib/baseUrl'

interface Props {
  lang: 'zh' | 'en'
  title?: string
}

const { lang, title = 'RuyiRepo Portal' } = Astro.props
const base = baseUrl()
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="any" />
    <title>{title}</title>
  </head>
  <body>
    <Header lang={lang} />
    <main class="main">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --text: #111827;
    --muted: #6b7280;
    --border: #e5e7eb;
    --card: #fafafa;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      Helvetica,
      Arial,
      'Apple Color Emoji',
      'Segoe UI Emoji';
  }

  .main {
    max-width: 72rem;
    margin: 0 auto;
    padding: 48px 16px 64px;
  }
</style>
